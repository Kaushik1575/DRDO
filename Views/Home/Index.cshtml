@{
    ViewData["Title"] = "Home";
}

<div class="landing-hero landing-hero-with-logo text-center">
    <h1 class="display-5 fw-bold">Apprenticeship Management System</h1>
    <p class="lead text-subtle mt-3">
        Manage apprenticeships, training, and administration in one place.
    </p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <p class="mt-4">Signed in as <strong>@User.Identity.Name</strong></p>
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-danger btn-lg mt-2" asp-controller="Admin" asp-action="Index">Go to Admin Panel</a>
        }
        else
        {
            <a class="btn btn-primary btn-lg mt-2" asp-controller="Apprentice" asp-action="Index">Go to Apprenticeship Panel</a>
        }
    }
    else
    {
        <div class="row g-4 mt-4 justify-content-center text-start">
            <div class="col-md-5">
                <div class="portal-card portal-card-lg portal-card-admin h-100">
                    <span class="badge bg-danger mb-2">Administrator</span>
                    <h3>Admin Portal</h3>
                    <p class="text-subtle">Register or login as admin to manage apprentices, records, and reports.</p>
                    <div class="d-grid gap-2">
                        <a class="btn btn-danger" asp-controller="Account" asp-action="AdminLogin">Admin Login</a>
                        <a class="btn btn-outline-danger" asp-controller="Account" asp-action="AdminRegister">Admin Register</a>
                    </div>
                </div>
            </div>
            <div class="col-md-5">
                <div class="portal-card portal-card-lg portal-card-apprentice h-100">
                    <span class="badge bg-primary mb-2">Apprenticeship</span>
                    <h3>Apprenticeship Portal</h3>
                    <p class="text-subtle">Register or login as apprenticeship to access training and submissions.</p>
                    <div class="d-grid gap-2">
                        <a class="btn btn-primary" asp-controller="Account" asp-action="ApprenticeLogin">Apprenticeship Login</a>
                        <a class="btn btn-outline-primary" asp-controller="Account" asp-action="ApprenticeRegister">Apprenticeship Register</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
