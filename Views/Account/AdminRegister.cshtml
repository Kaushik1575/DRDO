@model ApprenticeshipManagement.ViewModels.AdminRegisterViewModel
@{
    ViewData["Title"] = "Admin Registration";
}

<div class="auth-wrapper">
    <div class="auth-card auth-card-admin">
        <div class="auth-header text-center mb-4">
            <span class="badge bg-danger mb-2">Admin</span>
            <h2 class="auth-title">Admin Registration</h2>
            <p class="text-muted">Create an administrator account</p>
        </div>

        <form asp-action="AdminRegister" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="admin@drdo.gov.in" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Department" class="form-label"></label>
                <input asp-for="Department" class="form-control" placeholder="e.g. HR / Administration" />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-danger w-100">Register as Admin</button>
        </form>

        <p class="text-center mt-3 mb-0">
            Already registered?
            <a asp-action="AdminLogin">Admin Login</a>
        </p>
        <p class="text-center mt-2 mb-0 small">
            <a asp-controller="Home" asp-action="Index">Back to Home</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
