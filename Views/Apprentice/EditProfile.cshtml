@model ApprenticeshipManagement.ViewModels.EditApprenticeProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="apprenticeship-panel">
    <div class="card-soft p-4" style="max-width: 720px; margin: 0 auto;">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <h2 class="mb-0">Edit Profile</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Panel</a>
        </div>

        <form asp-action="EditProfile" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" readonly />
                </div>
                <div class="col-md-6">
                    <label asp-for="ApprenticeId" class="form-label"></label>
                    <input asp-for="ApprenticeId" class="form-control" readonly />
                </div>

                <div class="col-12">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="TradeField" class="form-label"></label>
                    <input asp-for="TradeField" class="form-control" />
                    <span asp-validation-for="TradeField" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MobileNumber" class="form-label"></label>
                    <input asp-for="MobileNumber" class="form-control" />
                    <span asp-validation-for="MobileNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="apprentice-form-actions d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

