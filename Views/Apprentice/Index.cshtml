@model ApprenticeshipManagement.ViewModels.ApprenticeDashboardViewModel
@{
    ViewData["Title"] = "Apprenticeship Panel";
}

<div class="apprenticeship-panel">
    <div class="apprenticeship-panel-header card-soft p-4 mb-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <h1 class="apprenticeship-panel-title mb-0">Apprenticeship Panel</h1>
            <div class="apprentice-header-actions d-flex gap-2">
                <a asp-action="EditProfile" class="btn btn-outline-primary">Edit Profile</a>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-apprentice-logout">Logout</button>
                </form>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card-soft p-4 mb-4">
        <div class="row align-items-center g-4">
            <div class="col-md-4">
                <div class="apprentice-profile d-flex align-items-center gap-3">
                    <div class="apprentice-avatar">&#128218;</div>
                    <div>
                        <h4 class="mb-0">@Model.FullName</h4>
                        <p class="text-subtle mb-0">@Model.TradeField</p>
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary") mt-1">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="row g-3">
                    <div class="col-sm-4">
                        <div class="stat-card stat-card-apprentice">
                            <div class="stat-label">Apprentice ID</div>
                            <div class="stat-value stat-value-sm">@Model.ApprenticeId</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="stat-card stat-card-apprentice">
                            <div class="stat-label">Days in Program</div>
                            <div class="stat-value">@Model.DaysInProgram</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="stat-card stat-card-apprentice">
                            <div class="stat-label">Registered On</div>
                            <div class="stat-value stat-value-sm">@Model.RegisteredOn.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-soft p-4 mb-4">
        <h3 class="panel-section-title mb-3">My Profile</h3>
        <div class="row g-3 profile-details">
            <div class="col-md-6 col-lg-3">
                <span class="profile-label">Full Name</span>
                <span class="profile-value">@Model.FullName</span>
            </div>
            <div class="col-md-6 col-lg-3">
                <span class="profile-label">Trade / Field</span>
                <span class="profile-value">@Model.TradeField</span>
            </div>
            <div class="col-md-6 col-lg-3">
                <span class="profile-label">Email</span>
                <span class="profile-value">@Model.Email</span>
            </div>
            <div class="col-md-6 col-lg-3">
                <span class="profile-label">Mobile</span>
                <span class="profile-value">@Model.MobileNumber</span>
            </div>
        </div>
    </div>

    <div class="card-soft p-4">
        <h3 class="panel-section-title mb-3">Program Overview</h3>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="module-card">
                    <div class="module-icon">&#128218;</div>
                    <h5>My Training</h5>
                    <p class="text-subtle mb-2">View program modules, schedules, and daily tasks.</p>
                    <span class="badge bg-primary">Coming soon</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="module-card">
                    <div class="module-icon">&#128197;</div>
                    <h5>Attendance</h5>
                    <p class="text-subtle mb-2">Track attendance records and leave status.</p>
                    <span class="badge bg-primary">Coming soon</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="module-card">
                    <div class="module-icon">&#128221;</div>
                    <h5>Assignments</h5>
                    <p class="text-subtle mb-2">Submit work and monitor evaluation progress.</p>
                    <span class="badge bg-primary">Coming soon</span>
                </div>
            </div>
        </div>
    </div>
</div>
