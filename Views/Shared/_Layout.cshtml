<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Apprenticeship Portal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ApprenticeshipManagement.styles.css" asp-append-version="true" />
</head>
<body class="page-bg">
    <header>
        <div class="app-header">
            <div class="container-lg">
                <div class="header-content d-flex align-items-center justify-content-between">
                    <div class="header-brand d-flex align-items-center gap-3">
                        <img src="/images/drdo-logo.png" alt="DRDO Logo" class="drdo-logo-sm">
                        <div>
                            <h1 class="header-title">Apprenticeship Management System</h1>
                            <p class="header-tagline">Skill Today, Success Tomorrow</p>
                        </div>
                    </div>
                    <nav class="navbar navbar-expand-lg navbar-dark ms-auto">
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                                aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="navbar-collapse collapse">
                            <ul class="navbar-nav ms-auto gap-1">
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-house"></i> Home
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#about">
                                        <i class="bi bi-info-circle"></i> About
                                    </a>
                                </li>
                                @if (User.Identity?.IsAuthenticated == false)
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-briefcase"></i> Admin
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" asp-controller="Account" asp-action="AdminLogin">Admin Login</a></li>
                                            <li><a class="dropdown-item" asp-controller="Account" asp-action="AdminRegister">Admin Register</a></li>
                                        </ul>
                                    </li>
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-person"></i> Apprentice
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" asp-controller="Account" asp-action="ApprenticeLogin">Apprentice Login</a></li>
                                            <li><a class="dropdown-item" asp-controller="Account" asp-action="ApprenticeRegister">Apprentice Register</a></li>
                                        </ul>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link" href="#contact">
                                        <i class="bi bi-envelope"></i> Contact
                                    </a>
                                </li>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Admin Panel</a></li>
                                            }
                                            else
                                            {
                                                <li><a class="dropdown-item" asp-controller="Apprentice" asp-action="Index">Apprenticeship Panel</a></li>
                                            }
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="dropdown-item text-danger">Logout</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </li>
                                }
                            </ul>
                        </div>
                    </nav>
                </div>
            </div>
        </div>
    </header>
    <div class="container-lg app-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="page-footer text-muted py-3 mt-4">
        <div class="container-lg d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>&copy; 2026 - Apprenticeship Management System</div>
            <div><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
